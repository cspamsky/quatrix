# Environment variables for backend

# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://quatrix:dev_password@localhost:5432/quatrix"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# CS2 Servers
CS2_SERVERS_PATH=/home/steam/cs2-servers
STEAMCMD_PATH=/home/steam/steamcmd

# Port Range for CS2 Servers
CS2_PORT_RANGE_START=27015
CS2_PORT_RANGE_END=27115
